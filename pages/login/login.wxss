/* pages/login/login.wxss */
page{
  background-color: #ffffff;
}

.container{/*整个容器在下面*/
  min-height: 100vh;
  padding:0rpx 30rpx 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  box-sizing: border-box;
}

.field{
display:flex;
align-items: center;
width: 100%;
height: 88rpx;
border-radius: 12rpx;
margin-bottom: 48rpx;
box-sizing: border-box;
border:2rpx solid #dddddd;
}

.field-label{
  width: 140rpx;
  font-size: 32rpx;
  color: #333333;
  text-align: center;
  flex-shrink: 0;
  line-height: 88rpx;
}

.input{
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333333;
  padding: 0 20rpx;
  border:2rpx solid #dddddd;
}

.input:focus{
  /*点击输入框边框点亮*/
  border-color: rgb(164,203,241);
}

.tip-field{
 width: 100%;
 padding: 0 30rpx;
 margin-bottom: 48rpx;
 box-sizing: border-box;
}

.tip-jiaowu{
  font-size: 28rpx;
  color: rgb(164,203,241);
  line-height: 88rpx;
  display: block;
}
/*登录按钮*/
.login-btn{
  width: 100%;
  height: 13rpx;
  width: 37rpx;
  line-height: 88rpx;
  background-color: rgb(164,173,179);
  color: #ffffff;
  font-size: 34rpx;
  border-radius: 12rpx;
  margin-top: 40rpx;
  border:none;
  text-align: center;
}

/*点击按钮效果*/
.btn-hover{
  background-color: rgb(164,203,241);
  opacity: 0.9;/*降低透明度*/
}