<!--pages/sell/sell.wxml-->
<view class="container">
<!-- 顶部导航栏 -->
  <view class="nav-back" bindtap="navBack">
    <text class="back-icon">{{'<'}}</text>
    <view class="nav-title">出售/预售</view>
 </view>

<!-- 出售/预售选择 -->
  <view class="radio-group">
    <view class="radio-item">
      <radio checked="true" color="#2385fa"></radio>
      <text class="radio-text">出售</text>
    </view>

    <label class="radio-item">
      <radio checked="false" color="#2385fa"></radio>
      <text class="radio-text">预购</text>
    </label>
  </view>

  <!-- 第一步插入图片 -->
  <view class="step">
    <text class="step-title">第一步</text>
    <view class="image-upload" bindtap="chooseImage">
    <text class="upload-text">插入图片</text>
    </view>
  </view>

<!-- 第二步商品信息 -->
  <view class="step">
    <text class="step-title">第二步</text>
    <view class="Info-box">
      <text class="Info-item">商品描述:</text>
      <input class="info-item" placeholder="请输入商品描述" bindinput="onDescribeInput" />

      <text class="Info-item">价格:</text>
      <input class="info-item" placeholder="请输入价格" bindinput="onPriceInput" />

      <text class="Info-item">用途:</text>
      <textarea class="info-item" placeholder="请输入用途" bindinput="onPurposeInput" />

      <text class="Info-item">交换地点:</text>
      <textarea class="info-item" placeholder="请输入交换地点" bindinput="onPpaceInput" />

    </view>
  </view>

  <!-- 发布按钮 -->
  <view class="publish-btn" bindtap="publish">
    <text class="pushlish-text">发布</text>
  </view>

</view>