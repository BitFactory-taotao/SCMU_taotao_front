/* pages/sell/sell.wxss */
page{
  width: 100%;
  height: 100%;
  background-color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI',sans-serif;
}

.container{
  width: 100%; 
  padding-bottom:60rpx;
  height: 100%;
}

.nav-bar{
  display:flex;
  /* 垂直居中 */
  align-items:center;
  height: 88rpx;
  padding: 0 ;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-back{
  width: 88rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 0;
  padding-left: 30rpx;
}

.back-icon{
  font-size: 40rpx;
  color: #333333;
}

.nav-title{
  font-size: 40rpx;
  font-weight: 500;
  color: #333333;
  margin-left:20rpx;
  /* 文字不换行 */
  white-space: nowrap;
}

.radio-group{
  padding: 40rpx 30rpx;
}

.radio-item {
  display: flex; 
  align-items: center;
  margin-bottom: 30rpx; 
}

.radio-item:last-child {
  margin-bottom: 0; 
}

.radio-text {
  width: 100%; 
  font-size: 32rpx;
  color: #333333;
  margin-left: 16rpx; 
}

.step {
  width: 100%; 
  padding: 0 30rpx 40rpx; 
}

.step-title {
  width: 100%; 
  font-size: 36rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 24rpx; 
  display: block;
}

.image-upload {
  width: 100%; 
  height: 300rpx; 
  background-color: #eaeaea; 
  display: flex;
  align-items: center;
  justify-content: center; 
}

.upload-text {
  font-size: 60rpx; 
  color: #333333;
}

.info-box {
  width: 100%;
  min-height: 300rpx; 
  border: 1rpx solid #d9d9d9; 
  padding: 24rpx; 
  box-sizing: border-box; 
}

.info-label {
  font-size: 32rpx;
  color: #333333;
  display: block;
  margin-bottom: 16rpx;
}

.info-item {
  font-size: 32rpx;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.info-item:last-child {
  margin-bottom: 0; 
}

.publish-btn {
  width: 200rpx; 
  height: 60rpx; 
  background-color: #c9c9c9; 
  border-radius: 4rpx; 
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 30rpx 0 auto;
}
.publish-text {
  font-size: 32rpx;
  color: #ffffff; 
}
